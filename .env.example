# Copy to .env and fill in values. Never commit .env.
# Secrets live in aigov-kv (Azure Key Vault) — pull with az keyvault secret show.

AZURE_TENANT_ID=4db4e22f-83ed-4093-8d8a-c73b1e559459
AZURE_CLIENT_ID=                        # from aigov-kv secret: aigov-client-id
AZURE_CLIENT_SECRET=                    # from aigov-kv secret: aigov-client-secret
AZURE_KEY_VAULT_URL=https://aigov-kv.vault.azure.net/

# aigov-db (PostgreSQL 16, East US 2)
DATABASE_URL=postgresql://USER:PASS@aigov-db.postgres.database.azure.com:5432/aigov

# aigov-openai-dev (eastus) — use gpt-4.1, NOT gpt-4o
AZURE_OPENAI_ENDPOINT=https://aigov-openai-dev.openai.azure.com/
# Deployments: aigov-gpt41 (150K TPM) | aigov-gpt41-mini (250K TPM, cost paths)

# aigov-search (Central US, Basic)
AZURE_SEARCH_ENDPOINT=https://aigov-search.search.windows.net
AZURE_SEARCH_KEY=                       # from aigov-kv secret: aigov-search-key

# aigov-graphdb-vm (172.210.64.73:7200) — GraphDB Free 10
GRAPHDB_ENDPOINT=http://172.210.64.73:7200
GRAPHDB_REPOSITORY=governance

# aigov-bus (Service Bus Basic) — NOT YET PROVISIONED (Phase 1 Step B)
SERVICE_BUS_CONNECTION_STRING=          # from aigov-kv secret: aigov-servicebus-connection-string

# aigov-redis — NOT YET PROVISIONED (Phase 1 Step A)
REDIS_CONNECTION_STRING=                # from aigov-kv secret: aigov-redis-connection-string
